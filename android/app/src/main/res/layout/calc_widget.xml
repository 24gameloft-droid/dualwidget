<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calc_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF111111"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="20"
        android:orientation="vertical"
        android:background="#FF9DB89A"
        android:padding="5dp">
        <TextView
            android:id="@+id/calc_expr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AA2A3A00"
            android:textSize="10sp"
            android:gravity="end"
            android:singleLine="true"
            android:ellipsize="start"/>
        <TextView
            android:id="@+id/calc_display"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="0"
            android:textColor="#FF1A2A00"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="end|center_vertical"
            android:singleLine="true"
            android:ellipsize="start"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="3dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="13" android:orientation="horizontal">
        <TextView android:id="@+id/btn_ac"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="AC"  android:textSize="13sp" android:textColor="#FFFFFFFF" android:background="#FFC62828" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_pm"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="+/-" android:textSize="11sp" android:textColor="#FFFFFFFF" android:background="#FF555555" android:layout_margin="2dp" android:gravity="center"/>
        <TextView android:id="@+id/btn_pct" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="%" android:textSize="14sp" android:textColor="#FFFFFFFF" android:background="#FF555555" android:layout_margin="2dp" android:gravity="center"/>
        <TextView android:id="@+id/btn_div" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="/" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF1565C0" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="13" android:orientation="horizontal">
        <TextView android:id="@+id/btn_7"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="7" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_8"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="8" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_9"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_mul" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="x" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF1565C0" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="13" android:orientation="horizontal">
        <TextView android:id="@+id/btn_4"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="4" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_5"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="5" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_6"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_sub" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="-" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF1565C0" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="13" android:orientation="horizontal">
        <TextView android:id="@+id/btn_1"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_2"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_3"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_add" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="+" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF1565C0" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="13" android:orientation="horizontal">
        <TextView android:id="@+id/btn_0"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" android:text="0" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_dot" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="." android:textSize="20sp" android:textColor="#FFFFFFFF" android:background="#FF333333" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_eq"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="=" android:textSize="16sp" android:textColor="#FFFFFFFF" android:background="#FFC62828" android:layout_margin="2dp" android:gravity="center" android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
